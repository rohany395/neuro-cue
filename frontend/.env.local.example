# Copy to .env.local (gitignored). Do not put secrets behind VITE_ variables;
# Vite bakes them into the public browser bundle.

# Where Vite proxies /api/* during `npm run dev` (defaults to production Vercel app)
# VITE_DEV_API_TARGET=https://neuro-cue.vercel.app

# Public Space URL — browser uploads video and runs predictions here.
VITE_SPACE_URL=https://rohany395-neuro-cue.hf.space/
