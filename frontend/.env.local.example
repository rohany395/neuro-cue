# Copy to .env.local (gitignored). Used by `vercel dev` and optional Vite proxy target.

# Server-only (never use VITE_ prefix for HF_TOKEN)
HF_TOKEN=hf_your_read_only_token
HF_SPACE_URL=https://rohany395-neuro-cue.hf.space/

# Shared gate for POST /api/predict (server + browser build must match)
# Generate: openssl rand -hex 32
PREDICT_API_SECRET=your_random_secret_here
VITE_PREDICT_API_KEY=your_random_secret_here

# Optional: comma-separated browser origins (defaults include localhost + production)
# ALLOWED_ORIGINS=https://neuro-cue.vercel.app,http://localhost:5173

# Optional rate limits per IP (best-effort on serverless)
# PREDICT_RATE_LIMIT_PER_MINUTE=5
# PREDICT_RATE_LIMIT_PER_HOUR=20

# Where Vite proxies /api/* during `npm run dev` (defaults to production Vercel app)
# VITE_DEV_API_TARGET=https://neuro-cue.vercel.app

# Optional: call a specific predict URL from the browser (usually leave unset; use /api/predict)
# VITE_PREDICT_PROXY_URL=/api/predict

# Public Space URL — browser uploads video here (bypasses Vercel 4.5MB body limit)
VITE_SPACE_URL=https://rohany395-neuro-cue.hf.space/
